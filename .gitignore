# Dependencies
/node_modules

# Production
/build

# Generated files
.docusaurus
.cache-loader

# Docs are copied from the touying submodule (touying/docs/{en,zh}/) at build
# time by scripts/copy-docs.py. Never commit these directly.
/docs/
# Except: reference pages are auto-generated by scripts/generate-docs.py at build
# time, also not committed. The /docs/ rule above already covers this, but keep
# the explicit entry as documentation.
# /docs/reference/

# Chinese docs are also copied from the submodule at build time.
/i18n/zh/docusaurus-plugin-content-docs/current/

# Typst source example files are no longer stored here; images are generated
# from ```example blocks in the documentation source at build time.
/src/typst/

# Typst-generated images (regenerated in CI from ```example blocks)
/static/img/typst-generated/

# Misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*
